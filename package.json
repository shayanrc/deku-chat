{
  "name": "deku-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/web",
    "apps/fullstack/frontend"
  ],
  "scripts": {
    "dev": "npm run dev:fullstack",
    "dev:fullstack": "concurrently -n api,web -c blue,magenta \"npm run dev:api\" \"npm run dev -w apps/fullstack/frontend\"",
    "dev:api": "uv --directory apps/fullstack/backend run uvicorn deku_server.main:app --reload --port 5175",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test -w packages/core && uv --directory apps/fullstack/backend run pytest -q",
    "lint:py": "uv --directory apps/fullstack/backend run ruff check ."
  },
  "dependencies": {},
  "devDependencies": {
    "concurrently": "^9.1.2",
    "playwright": "^1.61.1"
  }
}
