{
  "name": "deku-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/web",
    "apps/fullstack/frontend"
  ],
  "scripts": {
    "dev": "npm run dev:fullstack",
    "dev:fullstack": "concurrently -n api,web -c blue,magenta \"npm run dev:api\" \"npm run dev -w apps/fullstack/frontend\"",
    "dev:api": "uv --directory apps/fullstack/backend run uvicorn deku_server.main:app --reload --port 5175",
    "dev:web": "npm run dev -w apps/web",
    "dev:legacy": "concurrently -n server,web -c blue,magenta \"tsx watch server/index.ts\" \"npm run dev -w apps/fullstack/frontend\"",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present && tsc --noEmit -p tsconfig.json",
    "test": "npm run test -w packages/core && uv --directory apps/fullstack/backend run pytest -q",
    "lint:py": "uv --directory apps/fullstack/backend run ruff check ."
  },
  "dependencies": {
    "@langchain/anthropic": "^0.3.26",
    "@langchain/cohere": "^0.3.4",
    "@langchain/core": "^0.3.66",
    "@langchain/deepseek": "^0.1.0",
    "@langchain/google-genai": "^0.2.16",
    "@langchain/groq": "^0.2.4",
    "@langchain/langgraph": "^0.3.11",
    "@langchain/mistralai": "^0.2.3",
    "@langchain/openai": "^0.5.18",
    "@langchain/xai": "^0.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.0",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "playwright": "^1.61.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
